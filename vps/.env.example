# Скопіюй цей файл у vps/.env і встав реальні значення.
# vps/.env у .gitignore — НЕ commit'и реальні токени.

# Telegram bot для нотифікацій про статус uploads
# Створи bot через @BotFather, отримай token формату 123456:ABC...
TELEGRAM_BOT_TOKEN=

# Chat ID куди слати нотифікації (особистий чат або group)
# Дізнатись свій ID: написати @userinfobot
TELEGRAM_CHAT_ID=
